# PostgreSQL 接続文字列
# 例: postgresql://user:password@host:5432/accesslens
DATABASE_URL=postgresql://localhost:5432/accesslens

# ローカル開発では SSL を無効にする（本番は true のまま）
DATABASE_SSL=false

# JWT 署名シークレット（openssl rand -hex 32 で生成推奨）
JWT_SECRET=your-secret-here

# JWT の有効期限
JWT_EXPIRES_IN=30d

# Lemon Squeezy API キー（Settings > API ページから取得）
LEMONSQUEEZY_API_KEY=your-ls-api-key

# Lemon Squeezy Webhook シークレット（Phase 2-5 で設定）
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ログレベル（debug / info / warn / error）
LOG_LEVEL=info

# 本番では production に変更
NODE_ENV=development

# CORS で許可するオリジン（拡張機能は chrome-extension://* を指定）
CORS_ORIGIN=*

# ポート番号
PORT=3000
